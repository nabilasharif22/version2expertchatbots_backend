{
  "name": "scientist-debate-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Two-agent AI debate backend with scientist validation (CrossRef), SSE streaming, OpenAI + Anthropic, and SQLite/Prisma persistence.",
  "main": "src/server.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "db:reset": "rimraf prisma/dev.db && prisma migrate reset --force && prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@prisma/client": "^5.18.0",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.19.2",
    "openai": "^4.58.1",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.18.0",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}